<script>
function openMap(e, el) {
  e.preventDefault();
  var url = el.getAttribute('href');
  var w = window.open(url, '_blank', 'noopener,noreferrer');
  if (!w) { window.location.href = url; }
}

window.addEventListener('pageshow', function(event) {
  if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
    var env = document.getElementById('EnvelopeGate');
    if (env) { env.style.display = 'none'; }
    document.getElementById('sound-btn').style.display = 'flex';
  }
});

(function() {
  var box      = document.getElementById('SnakeBox');
  var svg      = document.getElementById('snakeSvg');
  var track    = document.getElementById('lineTrack');
  var fill     = document.getElementById('lineFill');
  var built    = false;
  var CX, H;
  var eventTops  = [140, 370, 600];
  var eventEls   = document.querySelectorAll('#SnakeBox .wed-event');
  var lineHearts = document.querySelectorAll('#SnakeBox .line-heart');

  function buildLine() {
    var W = box.getBoundingClientRect().width || Math.min(window.innerWidth - 48, 450);
    H = box.getBoundingClientRect().height || 760;
    CX = 24;
    svg.setAttribute('width', W);
    svg.setAttribute('height', H);
    svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
    track.setAttribute('x1', CX); track.setAttribute('y1', 0);
    track.setAttribute('x2', CX); track.setAttribute('y2', H);
    fill.setAttribute('x1', CX); fill.setAttribute('y1', 0);
    fill.setAttribute('x2', CX); fill.setAttribute('y2', 0);
    built = true;
  }

  function update() {
    if (!built) buildLine();
    var rect     = box.getBoundingClientRect();
    var winH     = window.innerHeight;
    var boxH     = rect.height;
    var entered  = winH - rect.top;
    var progress = entered / (boxH + winH);
    if (progress < 0) progress = 0;
    if (progress > 1) progress = 1;
    var fillY = progress * boxH;
    fill.setAttribute('y2', fillY);
    lineHearts.forEach(function(lh, i) {
      var path = lh.querySelector('.lh-path');
      var reached = fillY >= eventTops[i];
      if (reached) {
        path.setAttribute('fill', '#53332A');
        path.setAttribute('stroke', 'none');
        lh.classList.add('filled');
        if (eventEls[i]) { eventEls[i].style.opacity = '1'; }
      } else {
        path.setAttribute('fill', 'none');
        path.setAttribute('stroke', '#53332A');
        lh.classList.remove('filled');
        if (eventEls[i]) { eventEls[i].style.opacity = '0.4'; }
      }
    });
  }

  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', function() { built = false; buildLine(); update(); });
  function tryInit() {
    if (box.getBoundingClientRect().width > 10) { buildLine(); update(); }
    else { requestAnimationFrame(tryInit); }
  }
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', tryInit); }
  else { tryInit(); }
  window.addEventListener('load', function() { built = false; buildLine(); update(); });
})();

(function() {
  var target = new Date('2026-08-06T12:00:00'); // TODO: update to actual ceremony start time
  function pad(n) { return n < 10 ? '0' + n : '' + n; }
  function tick() {
    var now = new Date();
    var diff = target - now;
    if (diff < 0) diff = 0;
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    document.getElementById('cd-days').textContent  = pad(d);
    document.getElementById('cd-hours').textContent = pad(h);
    document.getElementById('cd-mins').textContent  = pad(m);
    document.getElementById('cd-secs').textContent  = pad(s);
  }
  tick();
  setInterval(tick, 1000);
})();

function rsvpSelect(el) {
  document.querySelectorAll('.rsvp-radio-label').forEach(function(l) { l.classList.remove('selected'); });
  el.classList.add('selected');
  el.querySelector('input[type=radio]').checked = true;
}
var rsvpForm = document.getElementById('rsvpForm');
if (rsvpForm) {
  rsvpForm.addEventListener('submit', function(e) {
    e.preventDefault();
    var data = new FormData(rsvpForm);
    fetch('https://formspree.io/f/mqewldnr', {
      method: 'POST', body: data, headers: { 'Accept': 'application/json' }
    }).then(function(res) {
      if (res.ok) {
        rsvpForm.style.display = 'none';
        var successEl = document.getElementById('rsvpSuccess');
        successEl.style.display = 'block';
        successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else { alert('Something went wrong. Please try again.'); }
    }).catch(function() { alert('Something went wrong. Please check your connection and try again.'); });
  });
}

var _bgAudio  = document.getElementById('bg-audio');
var _soundBtn = document.getElementById('sound-btn');
var _iconOn   = document.getElementById('icon-sound-on');
var _iconOff  = document.getElementById('icon-sound-off');
var _playing  = false;

function _setPlaying(val) {
  _playing = val;
  if (val) { _soundBtn.classList.add('playing'); _iconOn.style.display = 'block'; _iconOff.style.display = 'none'; }
  else { _soundBtn.classList.remove('playing'); _iconOn.style.display = 'none'; _iconOff.style.display = 'block'; }
}
function _playMusic() {
  _bgAudio.volume = 0.5;
  _bgAudio.play().then(function() { _setPlaying(true); }).catch(function(e) { console.log('audio blocked', e); });
}
_soundBtn.addEventListener('click', function(e) {
  e.stopPropagation();
  if (_playing) { _bgAudio.pause(); _setPlaying(false); } else { _playMusic(); }
});

window.openMe = function() {
  var env = document.getElementById('EnvelopeGate');
  env.classList.add('is-open');
  setTimeout(function() { env.style.background = 'transparent'; }, 400);
  setTimeout(function() { env.style.display = 'none'; }, 1100);
  setTimeout(function() { _soundBtn.style.display = 'flex'; }, 1200);
  _bgAudio.volume = 0.5;
  _bgAudio.play().then(function() { _setPlaying(true); }).catch(function(e) { console.log('audio error:', e); });
};
</script>
