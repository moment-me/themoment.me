Սիրով հրավիրում ենք Ձեզ ներկա գտնվելու մեր հարսանյաց արարողությանը:
<br>Ծանոթացեք ծրագրին և հաստատեք Ձեր ներկայությունը մինչև [ՀԱՍՏԱՏՄԱՆ ՎԵՐՋՆԱԺԱՄԿԵՏ]</p>

  <div class="calendar-card">
    <h3 class="calendar-title">Օգոստոս</h3>
    <div class="cal-grid-wrap">
      <object id="heartObj" class="heart-svg" type="image/svg+xml"
        data="https://cdn.shopify.com/s/files/1/0962/1140/3055/files/heart-date-01_svg.svg?v=1776789466"
        aria-hidden="true"></object>
      <script>
        document.getElementById('heartObj').addEventListener('load', function() {
          try {
            var svgDoc = this.contentDocument;
            if (!svgDoc) return;
            var svgEl = svgDoc.querySelector('svg');
            if (!svgEl) return;
            svgEl.style.color = '#53332A';
            svgDoc.querySelectorAll('path, line, polyline, polygon, circle, ellipse, rect').forEach(function(el) {
              var stroke = el.getAttribute('stroke');
              var fill = el.getAttribute('fill');
              if (!stroke || stroke === 'none' || stroke === 'white' || stroke === '#fff' || stroke === '#ffffff') {
                if (fill && fill !== 'none') { el.setAttribute('fill', '#53332A'); }
                else { el.setAttribute('stroke', '#53332A'); }
              }
              if (fill && (fill === 'white' || fill === '#fff' || fill === '#ffffff')) { el.setAttribute('fill', 'none'); }
            });
          } catch(e) {}
        });
      </script>
      <div class="cal-grid">
        <div class="cal-head">ՉՐՔ</div>
        <div class="cal-head active-head">ՀԻՆ</div>
        <div class="cal-head">ՈՒՐ</div>
        <div class="cal-cell">5</div>
        <div class="cal-cell active-cell"><span class="date-num">6</span></div>
        <div class="cal-cell">7</div>
